{
  "name": "playwright-e2e-automation",
  "version": "1.0.0",
  "description": "E2E Automation with Playwright + Cucumber + Allure + SonarQube",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json}'",
    "security:audit": "npm audit && snyk test",
    "sonarqube": "sonar-scanner",
    "prepare": "husky install"
  },
  "keywords": ["playwright", "cucumber", "bdd", "automation", "testing"],
  "author": "jvelardcrepo-web",
  "license": "MIT",
  "dependencies": {
    "@cucumber/cucumber": "^9.5.1",
    "@cucumber/html-formatter": "^20.3.1",
    "@cucumber/messages": "^20.0.0",
    "@playwright/test": "^1.40.1",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "allure-commandline": "^2.27.0",
    "snyk": "^1.1282.0"
  }
}
